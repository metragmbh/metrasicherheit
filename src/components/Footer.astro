---
const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { label: 'Baustellensicherheit', href: '/leistungen#baustellensicherheit' },
    { label: 'Objektschutz', href: '/leistungen#objektschutz' },
    { label: 'Brandwachen', href: '/leistungen#brandwachen' },
    { label: 'Empfangs- & Concierge-Dienste', href: '/leistungen#concierge' },
    { label: 'Werkschutz', href: '/leistungen#werkschutz' },
  ],
  company: [
    { label: 'Über uns', href: '/' },
    { label: 'Leistungen', href: '/leistungen' },
    { label: 'Kontakt', href: '/kontakt' },
  ],
  legal: [
    { label: 'Impressum', href: '/impressum' },
    { label: 'Datenschutz', href: '/datenschutz' },
  ],
};

const contactInfo = {
  company: 'METRA Sicherheitsdienste GmbH',
  address: 'Im Mediapark 5',
  city: '50670 Köln',
  phone: '08008888369',
  phoneDisplay: '0800 8888 369',
  email: 'info@metra-sicherheitsdienste.de',
};
---

<footer class="bg-background/30 border-t border-white/5 mt-auto">
  <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-10 sm:py-12 md:py-16">
    <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8 lg:gap-12">
      
      <!-- Company Info -->
      <div class="col-span-2 md:col-span-2 lg:col-span-1 mb-4 sm:mb-0">
        <a href="/" class="flex items-center gap-2 mb-3 sm:mb-4" aria-label="METRA Sicherheitsdienste - Zur Startseite">
          <img 
            src="/images/logoneu.png" 
            alt="" 
            class="h-12 sm:h-16 w-auto object-contain"
            width="180"
            height="60"
          />
        </a>
        <p class="text-accent text-sm sm:text-base md:text-lg font-semibold mb-2 sm:mb-4">
          Schutz · Präsenz · Verantwortung
        </p>
        <p class="text-secondary text-xs sm:text-sm">
          {contactInfo.company}
        </p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold mb-2 sm:mb-4 text-sm sm:text-base">Leistungen</h3>
        <ul class="space-y-1.5 sm:space-y-2">
          {footerLinks.services.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-secondary text-xs sm:text-sm hover:text-accent transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded py-1.5 inline-flex items-center"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company Links -->
      <div>
        <h3 class="text-white font-semibold mb-2 sm:mb-4 text-sm sm:text-base">Unternehmen</h3>
        <ul class="space-y-1.5 sm:space-y-2">
          {footerLinks.company.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-secondary text-xs sm:text-sm hover:text-accent transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded py-1.5 inline-flex items-center"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="col-span-2 sm:col-span-1 mt-4 sm:mt-0">
        <h3 class="text-white font-semibold mb-2 sm:mb-4 text-sm sm:text-base">Kontakt</h3>
        <ul class="space-y-2 sm:space-y-3">
          <li>
            <a 
              href={`tel:${contactInfo.phone}`}
              class="flex items-center gap-2 text-secondary text-xs sm:text-sm hover:text-accent transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded py-1.5"
              aria-label={`Telefon: ${contactInfo.phoneDisplay}`}
            >
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 012 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {contactInfo.phoneDisplay}
            </a>
          </li>
          <li>
            <a 
              href={`mailto:${contactInfo.email}`}
              class="flex items-center gap-2 text-secondary text-xs sm:text-sm hover:text-accent transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded py-1.5"
              aria-label={`E-Mail: ${contactInfo.email}`}
            >
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span class="break-all">{contactInfo.email}</span>
            </a>
          </li>
        </ul>
        
        <!-- WhatsApp CTA - BRAND COLOR -->
        <a 
          href="https://wa.me/491738888378"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-4 px-4 py-2 bg-accent text-background text-sm font-semibold rounded hover:bg-accent-hover transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent min-h-[44px]"
          aria-label="Über WhatsApp kontaktieren"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="mt-6 sm:mt-8 p-3 sm:p-4 bg-white/5 border border-white/10 rounded-lg">
      <p class="text-secondary text-xs text-center">
        <span class="text-accent font-medium">Wichtiger Hinweis:</span> Sicherheitsdienstleistungen erfolgen im Rahmen der gesetzlichen Bestimmungen nach § 34a GewO.
      </p>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-6 sm:mt-8 pt-6 sm:pt-8 border-t border-white/5">
      <div class="flex flex-col-reverse md:flex-row items-center justify-between gap-4">
        <p class="text-secondary text-xs sm:text-sm text-center md:text-left">
          © {currentYear} {contactInfo.company}. Alle Rechte vorbehalten.
        </p>
        <nav aria-label="Rechtliche Links">
          <ul class="flex items-center gap-4 sm:gap-6">
            {footerLinks.legal.map((link) => (
              <li>
                <a 
                  href={link.href}
                  class="text-secondary text-xs sm:text-sm hover:text-accent transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded py-1.5 inline-flex items-center"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </div>
  </div>
</footer>
