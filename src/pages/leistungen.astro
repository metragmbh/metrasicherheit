---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const services = [
  {
    id: 'objektschutz',
    title: 'Objektschutz',
    description: 'Bewachung von Bürogebäuden, Wohnanlagen und Gewerbeobjekten mit klar geregelten Kontroll- und Meldeprozessen. Die Umsetzung erfolgt durch strukturierte Zutrittskontrollen, regelmäßige Kontrollgänge und definierte Abläufe zur Sicherstellung des Schutzes von Personen und Sachwerten.',
    image: '/images/service-objekt.webp',
    features: [
      'Zugangskontrolle und Besuchermanagement',
      'Revier- und Streifendienste',
      'Überwachung sensibler Bereiche',
      'Alarmverfolgung und Meldewesen',
      'Dokumentation aller sicherheitsrelevanten Vorgänge',
    ],
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  },
  {
    id: 'baustellensicherheit',
    title: 'Baustellensicherheit',
    description: 'Strukturierte Absicherung aktiver Baustellen – von innerstädtischen Projekten bis zu langfristigen Bauvorhaben. Kontrollierte Zugänge, Schutz von Materialien und definierte Sicherheitsabläufe erfolgen in Abstimmung mit Bauleitung und beteiligten Gewerken.',
    image: '/images/service-baustelle.webp',
    features: [
      'Zugangskontrolle und Personensteuerung',
      'Kontrollgänge und Streifendienste',
      'Schutz von Materialien und Maschinen',
      'Nacht- und Wochenendbewachung',
      'Abstimmung mit Bauleitung',
    ],
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  },
  {
    id: 'werkschutz',
    title: 'Werkschutz',
    description: 'Sicherung von Produktions- und Logistikstandorten unter Berücksichtigung betrieblicher Abläufe und interner Sicherheitsanforderungen. Integration in bestehende Prozesse mit klar definierten Zuständigkeiten und strukturierten Kontrollmaßnahmen.',
    image: '/images/service-werk.webp',
    features: [
      'Zutrittskontrolle für Mitarbeiter und Besucher',
      'Kontrolle von Zufahrten und Werksgeländen',
      'Streifen- und Revierdienste',
      'Fahrzeug- und Ladungskontrollen',
      'Dokumentation und Berichterstattung',
    ],
    icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  },
  {
    id: 'brandwachen',
    title: 'Brandwachen – rechtssicher und einsatzbereit',
    description: 'Bei Schweiß-, Schneid-, Löt- und anderen feuergefährlichen Arbeiten schreibt die DGUV Vorschrift 1 in Verbindung mit BGR 133 den Einsatz einer qualifizierten Brandwache vor. METRA stellt zertifizierte Brandschutzhelfer bereit – aktiv überwachend, sofort eingreifend, präzise dokumentierend. Kein Haftungsrisiko für den Auftraggeber.',
    image: '/images/service-brandwache.webp',
    features: [
      'Rechtskonforme Besetzung nach DGUV Vorschrift 1 / BGR 133',
      'Zertifizierte Brandschutzhelfer – Nachweise jederzeit vorlegbar',
      'Kontinuierliche Überwachung der Brandlast',
      'Sofortige Einleitung von Erstmaßnahmen',
      'Evakuierungsunterstützung bei Bedarf',
      'Revisionssichere Dokumentation aller Maßnahmen',
    ],
    icon: 'M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z',
  },
  {
    id: 'concierge',
    title: 'Empfang & Concierge',
    description: 'Kombination aus Zutrittskontrolle und Empfangsdienstleistungen. Die Umsetzung erfolgt nach definierten Unternehmensvorgaben und unterstützt strukturierte Besucher- und Dienstleisterprozesse.',
    image: '/images/service-concierge.webp',
    features: [
      'Besuchererfassung und Zutrittskontrolle',
      'Berechtigungsprüfung und Dokumentation',
      'Koordination von Besuchern und Dienstleistern',
      'Steuerung von Empfangsprozessen',
      'Umsetzung nach Unternehmensrichtlinien',
    ],
    icon: 'M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];

const benefits = [
  {
    title: 'Ein Ansprechpartner',
    description: 'Für die komplette Sicherheit – keine Kommunikationsbrüche.',
    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
  },
  {
    title: 'Klare Verantwortlichkeiten',
    description: 'Transparente Zuständigkeiten und lückenlose Dokumentation.',
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
  {
    title: '24/7 Verfügbarkeit',
    description: 'Rund um die Uhr für Sie da – auch an Wochenenden und Feiertagen.',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Praxisorientierte Lösungen',
    description: 'Unsere Konzepte orientieren sich an realen Sicherheitsanforderungen.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'Revisionssichere Dokumentation',
    description: 'Lückenlose Aufzeichnung aller sicherheitsrelevanten Vorgänge.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    title: 'Flexible Einsatzplanung',
    description: 'Anpassung an Projektgröße, Baufortschritt und individuelle Anforderungen.',
    icon: 'M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4',
  },
];

const trustBadges = [
  { text: '§34a GewO' },
  { text: 'IHK-geprüft' },
  { text: 'Dokumentation' },
  { text: 'Versicherungsschutz' },
];

const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Startseite',
      item: 'https://www.metra-sicherheitsdienste.de',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Leistungen',
      item: 'https://www.metra-sicherheitsdienste.de/leistungen',
    },
  ],
};

const schemaService = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Sicherheitsdienste',
  provider: {
    '@type': 'Organization',
    name: 'METRA Sicherheitsdienste GmbH',
  },
  areaServed: {
    '@type': 'City',
    name: 'Köln',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Sicherheitsdienstleistungen',
    itemListElement: services.map((service, index) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: service.title,
        description: service.description,
      },
    })),
  },
};
---

<Layout 
  title="Leistungen | METRA Sicherheitsdienste GmbH"
  description="Sicherheitsleistungen für definierte Einsatzbereiche. Strukturiert geplant und verbindlich umgesetzt – für Baustellen, Objekte und Industrie."
  canonical="/leistungen"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaService)} />
  
  <Header />
  <MobileMenu />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="relative py-20 md:py-32 overflow-hidden" aria-labelledby="services-hero-title">
      <div class="absolute inset-0 opacity-5" aria-hidden="true">
        <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
      </div>
      
      <div class="relative max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <nav aria-label="Breadcrumb">
            <ol class="flex items-center gap-2 text-sm text-secondary mb-6">
              <li><a href="/" class="hover:text-accent transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded">Startseite</a></li>
              <li aria-hidden="true">/</li>
              <li aria-current="page" class="text-accent">Leistungen</li>
            </ol>
          </nav>
          
          <p class="text-accent font-semibold tracking-wider text-sm mb-4">LEISTUNGEN</p>
          <h1 id="services-hero-title" class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
            Sicherheitsleistungen für definierte Einsatzbereiche
          </h1>
          <p class="text-lg md:text-xl text-secondary leading-relaxed max-w-2xl">
            Strukturiert geplant und verbindlich umgesetzt – für Baustellen, Objekte und Industrie.
          </p>
        </div>
      </div>
    </section>

    <!-- Trust Badges Section -->
    <section class="py-12 md:py-16 bg-background/30 border-y border-white/5" aria-labelledby="trust-title">
      <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="text-center mb-8">
          <h2 id="trust-title" class="text-xl md:text-2xl font-bold text-white mb-2">
            Zertifiziert für professionelle Einsatzbereiche
          </h2>
        </div>
        
        <div class="flex flex-wrap justify-center gap-4 md:gap-8">
          {trustBadges.map((badge) => (
            <div class="flex items-center gap-2 px-4 py-2 bg-white/5 rounded-lg">
              <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-secondary text-sm font-medium">{badge.text}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Services Detail Section WITH IMAGES -->
    <section class="py-20 md:py-32 bg-background/20" aria-labelledby="services-detail-title">
      <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
        <h2 id="services-detail-title" class="sr-only">Detaillierte Leistungsübersicht</h2>
        
        <div class="space-y-20 md:space-y-32">
          {services.map((service, index) => (
            <article 
              id={service.id}
              class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center"
            >
              
              {/* Image - alternates left/right */}
              <div class={`relative ${index % 2 === 1 ? 'lg:order-2' : ''}`}>
                <div class="relative rounded-2xl overflow-hidden aspect-[16/9]">
                  <img 
                    src={service.image} 
                    alt={service.title}
                    class={`w-full h-full object-cover ${service.id === 'brandwachen' ? 'object-top' : 'object-center'}`}
                    loading="lazy"
                    decoding="async"
                    width="600"
                    height="338"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-background/80 via-transparent to-transparent"></div>
                </div>
                
                {/* Decorative element */}
                <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-accent/10 rounded-full blur-2xl" aria-hidden="true"></div>
              </div>
              
              {/* Content */}
              <div class={index % 2 === 1 ? 'lg:order-1' : ''}>
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm font-medium mb-4 bg-accent/10 text-accent">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon}/>
                  </svg>
                  Leistungsbereich
                </div>
                <h3 class="text-2xl md:text-3xl font-bold mb-4 text-white">
                  {service.title}
                </h3>
                <p class="text-secondary text-lg leading-relaxed mb-6">
                  {service.description}
                </p>
                
                <h4 class="text-white font-semibold mb-3">Leistungsumfang:</h4>
                <ul class="space-y-2">
                  {service.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                      </svg>
                      <span class="text-secondary">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Benefits Section -->
    <section class="py-20 md:py-32" aria-labelledby="benefits-title">
      <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <p class="text-accent font-semibold tracking-wider text-sm mb-3">DIFFERENZIERUNG</p>
          <h2 id="benefits-title" class="text-3xl md:text-4xl font-bold text-white mb-4">
            Struktur und Verantwortung im Einsatz
          </h2>
        </div>
        
        <div class="grid md:grid-cols-3 gap-8">
          {benefits.map((benefit) => (
            <div class="text-center">
              <div class="w-16 h-16 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={benefit.icon}/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white mb-2">{benefit.title}</h3>
              <p class="text-secondary">{benefit.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process Teaser -->
    <section class="py-20 md:py-32 bg-background/20" aria-labelledby="process-teaser-title">
      <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-accent font-semibold tracking-wider text-sm mb-3">UNSER VORGEHEN</p>
            <h2 id="process-teaser-title" class="text-3xl md:text-4xl font-bold text-white mb-4">
              Strukturiert zum Sicherheitserfolg
            </h2>
            <p class="text-secondary text-lg mb-6">
              Unser bewährter 4-Schritte-Ansatz garantiert eine professionelle Abwicklung Ihres Sicherheitsprojekts – von der ersten Analyse bis zum finalen Reporting.
            </p>
            <a 
              href="/#process-title"
              class="inline-flex items-center text-accent font-semibold hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded"
            >
              4-Schritte-Ansatz ansehen
              <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            {[
              { title: 'Analyse', desc: 'Objektbegehung und Risikoerhebung vor Ort' },
              { title: 'Konzept', desc: 'Individuelles Sicherheitskonzept mit klarer Struktur' },
              { title: 'Einsatz', desc: 'Gesteuerter Einsatzbeginn mit Fachpersonal' },
              { title: 'Reporting', desc: 'Strukturierte Dokumentation und Abstimmung' },
            ].map((step) => (
              <div class="bg-background border border-white/5 rounded-xl p-6 text-center">
                <h3 class="text-white font-semibold mb-1">{step.title}</h3>
                <p class="text-secondary text-sm">{step.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 md:py-32" aria-labelledby="services-cta-title">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative bg-accent rounded-2xl p-8 md:p-16 overflow-hidden">
          <div class="absolute inset-0 opacity-10" aria-hidden="true">
            <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, #00002e 1px, transparent 0); background-size: 24px 24px;"></div>
          </div>
          
          <div class="relative text-center">
            <h2 id="services-cta-title" class="text-3xl md:text-4xl lg:text-5xl font-bold text-background mb-4">
              Lassen Sie uns Ihr Projekt absichern.
            </h2>
            <p class="text-background/80 text-lg md:text-xl mb-8 max-w-2xl mx-auto">
              Beschreiben Sie Ihr Projekt. Auf dieser Grundlage erfolgt eine strukturierte Bewertung und Abstimmung der weiteren Schritte.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a 
                href="/kontakt"
                class="inline-flex items-center justify-center px-8 py-4 bg-background text-white font-bold text-base rounded hover:bg-background/90 transition-colors focus:outline-none focus-visible:ring-4 focus-visible:ring-background/50"
                aria-label="Sicherheitskonzept anfragen"
              >
                Sicherheitskonzept anfragen →
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Hinweis Section removed - only in footer */}
  </main>
  
  <Footer />
  <WhatsAppButton />
</Layout>
