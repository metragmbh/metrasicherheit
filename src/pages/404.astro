---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "404 - Seite nicht gefunden | METRA Sicherheitsdienste";
const description = "Die angeforderte Seite konnte nicht gefunden werden. Zurück zur Startseite von METRA Sicherheitsdienste.";
---

<Layout title={title} description={description} canonical="/404">
  <Header />
  <main id="main-content" class="flex-grow flex items-center justify-center py-24 md:py-32">
    <div class="text-center max-w-2xl mx-auto px-4">
      <span class="text-8xl font-bold text-accent/20">404</span>
      <h1 class="text-3xl md:text-4xl font-bold text-white mt-4 mb-6">Seite nicht gefunden</h1>
      <p class="text-secondary text-lg mb-8">
        Die von Ihnen gesuchte Seite existiert nicht oder wurde verschoben.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/" 
          class="inline-flex items-center justify-center px-8 py-4 bg-accent text-background font-bold rounded hover:bg-accent-hover transition-colors focus:outline-none focus-visible:ring-4 focus-visible:ring-accent/50"
        >
          Zurück zur Startseite
        </a>
        <a 
          href="/kontakt" 
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-secondary/30 text-white font-semibold rounded hover:border-accent hover:text-accent transition-colors focus:outline-none focus-visible:ring-4 focus-visible:ring-accent/50"
        >
          Kontakt aufnehmen
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
