---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const contactInfo = {
  company: 'METRA Sicherheitsdienste GmbH',
  owner: 'Sascha Trajkovic',
  address: 'Im Mediapark 5',
  city: '50670 Köln',
  phone: '01708888891',
  phoneDisplay: '0170 888 88 91',
  email: 'info@metra-sicherheitsdienste.de',
  web: 'www.metra-sicherheitsdienste.de',
};

// Web3Forms Configuration
const WEB3FORMS_ENDPOINT = 'https://api.web3forms.com/submit';
const WEB3FORMS_ACCESS_KEY = 'YOUR_ACCESS_KEY'; // User needs to replace this

const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Startseite',
      item: 'https://www.metra-sicherheitsdienste.de',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Kontakt',
      item: 'https://www.metra-sicherheitsdienste.de/kontakt',
    },
  ],
};

const schemaContactPage = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Kontakt - METRA Sicherheitsdienste',
  description: 'Kontaktieren Sie METRA Sicherheitsdienste für Ihr Sicherheitsprojekt. Wir sind 24/7 für Sie da.',
  mainEntity: {
    '@type': 'Organization',
    name: contactInfo.company,
    address: {
      '@type': 'PostalAddress',
      streetAddress: contactInfo.address,
      addressLocality: 'Köln',
      postalCode: '50670',
      addressCountry: 'DE',
    },
    telephone: `+49${contactInfo.phone}`,
    email: contactInfo.email,
    url: `https://${contactInfo.web}`,
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: `+49${contactInfo.phone}`,
      contactType: 'customer service',
      availableLanguage: ['German'],
    },
  },
};
---

<Layout 
  title="Kontakt | METRA Sicherheitsdienste GmbH"
  description="Kontaktieren Sie METRA Sicherheitsdienste. Telefon: 0170 888 88 91 | E-Mail: info@metra-sicherheitsdienste.de | Adresse: Im Mediapark 5, 50670 Köln. 24/7 erreichbar."
  canonical="/kontakt"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaContactPage)} />
  
  <Header />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="relative py-20 md:py-24 overflow-hidden" aria-labelledby="contact-hero-title">
      <div class="absolute inset-0 opacity-5" aria-hidden="true">
        <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
      </div>
      
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <nav aria-label="Breadcrumb">
            <ol class="flex items-center gap-2 text-sm text-secondary mb-6">
              <li><a href="/" class="hover:text-accent transition-colors">Startseite</a></li>
              <li aria-hidden="true">/</li>
              <li aria-current="page" class="text-accent">Kontakt</li>
            </ol>
          </nav>
          
          <p class="text-accent font-semibold tracking-wider text-sm mb-4">KONTAKT</p>
          <h1 id="contact-hero-title" class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
            Sprechen Sie uns an
          </h1>
          <p class="text-lg md:text-xl text-secondary leading-relaxed max-w-2xl">
            Ob per Telefon, E-Mail oder WhatsApp – wir sind für Sie da. Lassen Sie uns gemeinsam Ihre Sicherheitsanforderungen besprechen.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-16 md:py-24 bg-black/20" aria-labelledby="contact-form-title">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
          
          <!-- Contact Info Sidebar -->
          <div class="lg:col-span-2">
            <h2 class="text-2xl font-bold text-white mb-6">Kontaktdaten</h2>
            
            <div class="space-y-6">
              <!-- Address -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold mb-1">Adresse</h3>
                  <address class="not-italic text-secondary">
                    <p class="font-medium text-white">{contactInfo.company}</p>
                    <p>{contactInfo.owner}</p>
                    <p>{contactInfo.address}</p>
                    <p>{contactInfo.city}</p>
                  </address>
                </div>
              </div>
              
              <!-- Phone -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 012 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold mb-1">Telefon</h3>
                  <p class="text-secondary mb-1">24/7 erreichbar</p>
                  <a 
                    href={`tel:${contactInfo.phone}`}
                    class="text-accent font-semibold hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded"
                    aria-label={`Anrufen: ${contactInfo.phoneDisplay}`}
                  >
                    {contactInfo.phoneDisplay}
                  </a>
                </div>
              </div>
              
              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold mb-1">E-Mail</h3>
                  <a 
                    href={`mailto:${contactInfo.email}`}
                    class="text-accent font-semibold hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded break-all"
                    aria-label={`E-Mail: ${contactInfo.email}`}
                  >
                    {contactInfo.email}
                  </a>
                </div>
              </div>
              
              <!-- WhatsApp -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold mb-1">WhatsApp</h3>
                  <p class="text-secondary mb-1">Schnell & unkompliziert</p>
                  <a 
                    href={`https://wa.me/49${contactInfo.phone}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center text-accent font-semibold hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded"
                    aria-label="Über WhatsApp kontaktieren"
                  >
                    Nachricht senden
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
            
            <!-- Quick Response Promise -->
            <div class="mt-8 p-6 bg-accent/5 border border-accent/10 rounded-xl">
              <div class="flex items-center gap-3 mb-2">
                <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                </svg>
                <span class="text-white font-semibold">Schnelle Antwort garantiert</span>
              </div>
              <p class="text-secondary text-sm">
                Wir melden uns innerhalb von 24 Stunden bei Ihnen. Bei dringenden Anliegen erreichen Sie uns telefonisch rund um die Uhr.
              </p>
            </div>
          </div>
          
          <!-- Contact Form -->
          <div class="lg:col-span-3">
            <div class="bg-background border border-white/5 rounded-2xl p-8 md:p-10">
              <h2 id="contact-form-title" class="text-2xl font-bold text-white mb-2">Schreiben Sie uns</h2>
              <p class="text-secondary mb-8">
                Füllen Sie das Formular aus – wir melden uns umgehend bei Ihnen.
              </p>
              
              <form 
                action={WEB3FORMS_ENDPOINT}
                method="POST"
                id="contact-form"
                class="space-y-6"
                aria-label="Kontaktformular"
              >
                <!-- Web3Forms Access Key -->
                <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
                
                <!-- Subject (Hidden) -->
                <input type="hidden" name="subject" value="Neue Kontaktanfrage über metra-sicherheitsdienste.de" />
                
                <!-- From Name (Hidden) -->
                <input type="hidden" name="from_name" value="METRA Sicherheitsdienste Website Kontaktformular" />
                
                <!-- Reply To (will be set by JS) -->
                <input type="hidden" name="replyto" id="replyto-field" />
                
                <!-- Honeypot Field (Anti-Spam) - Must remain empty -->
                <div class="hidden" aria-hidden="true">
                  <input 
                    type="text" 
                    name="botcheck" 
                    id="botcheck"
                    tabindex="-1" 
                    autocomplete="off"
                    aria-hidden="true"
                  />
                </div>
                
                <!-- Name Field -->
                <div>
                  <label for="name" class="block text-white font-medium mb-2">
                    Name <span class="text-accent">*</span>
                  </label>
                  <input 
                    type="text"
                    id="name"
                    name="name"
                    required
                    autocomplete="name"
                    class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-secondary/50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors"
                    placeholder="Ihr vollständiger Name"
                    aria-required="true"
                  />
                </div>
                
                <!-- Email Field -->
                <div>
                  <label for="email" class="block text-white font-medium mb-2">
                    E-Mail <span class="text-accent">*</span>
                  </label>
                  <input 
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
                    class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-secondary/50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors"
                    placeholder="ihre@email.de"
                    aria-required="true"
                  />
                </div>
                
                <!-- Phone Field -->
                <div>
                  <label for="phone" class="block text-white font-medium mb-2">
                    Telefon
                  </label>
                  <input 
                    type="tel"
                    id="phone"
                    name="phone"
                    autocomplete="tel"
                    class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-secondary/50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors"
                    placeholder="0170 123 45 67"
                  />
                </div>

                <!-- Service Interest -->
                <div>
                  <label for="service" class="block text-white font-medium mb-2">
                    Interessierte Leistung
                  </label>
                  <select 
                    id="service"
                    name="service"
                    class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors"
                  >
                    <option value="" class="bg-background">Bitte wählen...</option>
                    <option value="baustellensicherheit" class="bg-background">Baustellensicherheit</option>
                    <option value="objektschutz" class="bg-background">Objektschutz</option>
                    <option value="brandwachen" class="bg-background">Brandwachen</option>
                    <option value="concierge" class="bg-background">Empfangs- & Concierge-Dienste</option>
                    <option value="werkschutz" class="bg-background">Werkschutz / Industrieschutz</option>
                    <option value="sonstiges" class="bg-background">Sonstiges</option>
                  </select>
                </div>
                
                <!-- Message Field -->
                <div>
                  <label for="message" class="block text-white font-medium mb-2">
                    Nachricht <span class="text-accent">*</span>
                  </label>
                  <textarea 
                    id="message"
                    name="message"
                    required
                    rows="5"
                    class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-secondary/50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors resize-none"
                    placeholder="Beschreiben Sie Ihr Projekt oder Ihre Sicherheitsanforderungen..."
                    aria-required="true"
                  ></textarea>
                </div>
                
                <!-- Privacy Checkbox -->
                <div class="flex items-start gap-3">
                  <input 
                    type="checkbox"
                    id="privacy"
                    name="privacy"
                    required
                    class="w-5 h-5 mt-0.5 rounded border-white/10 bg-white/5 text-accent focus:ring-accent focus:ring-offset-0 cursor-pointer"
                    aria-required="true"
                  />
                  <label for="privacy" class="text-secondary text-sm">
                    Ich habe die <a href="/datenschutz" class="text-accent hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zu. <span class="text-accent">*</span>
                  </label>
                </div>
                
                <!-- Submit Button -->
                <button 
                  type="submit"
                  id="submit-btn"
                  class="w-full inline-flex items-center justify-center px-8 py-4 bg-accent text-background font-bold text-base rounded hover:bg-accent-hover transition-colors focus:outline-none focus-visible:ring-4 focus-visible:ring-accent/50 disabled:opacity-50 disabled:cursor-not-allowed"
                  aria-label="Nachricht senden"
                >
                  <span id="btn-text">Nachricht senden</span>
                  <svg id="btn-icon" class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                  </svg>
                  <svg id="btn-spinner" class="w-5 h-5 ml-2 hidden animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </button>
                
                <!-- Success Message -->
                <div 
                  id="success-message" 
                  class="hidden p-4 bg-green-500/10 border border-green-500/30 rounded-lg"
                  role="alert"
                  aria-live="polite"
                >
                  <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <div>
                      <p class="text-white font-medium">Vielen Dank für Ihre Nachricht!</p>
                      <p class="text-secondary text-sm mt-1">Wir haben Ihre Anfrage erhalten und werden uns innerhalb von 24 Stunden bei Ihnen melden.</p>
                    </div>
                  </div>
                </div>
                
                <!-- Error Message -->
                <div 
                  id="error-message" 
                  class="hidden p-4 bg-red-500/10 border border-red-500/30 rounded-lg"
                  role="alert"
                  aria-live="polite"
                >
                  <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                    </svg>
                    <div>
                      <p class="text-white font-medium">Es ist ein Fehler aufgetreten.</p>
                      <p class="text-secondary text-sm mt-1">Bitte versuchen Sie es später erneut oder kontaktieren Sie uns telefonisch.</p>
                    </div>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>


  </main>
  
  <Footer />
  <WhatsAppButton />
</Layout>

<script>
  // Form handling
  (function() {
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const btnIcon = document.getElementById('btn-icon');
    const btnSpinner = document.getElementById('btn-spinner');
    const successMessage = document.getElementById('success-message');
    const errorMessage = document.getElementById('error-message');
    const replyToField = document.getElementById('replyto-field');
    const emailField = document.getElementById('email');
    
    if (!form) return;
    
    // Update replyto field when email changes
    emailField?.addEventListener('input', function() {
      if (replyToField) {
        replyToField.value = this.value;
      }
    });
    
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      // Check honeypot - if filled, it's a bot
      const botcheck = document.getElementById('botcheck');
      if (botcheck && botcheck.value) {
        return;
      }
      
      // Show loading state
      if (submitBtn) submitBtn.disabled = true;
      if (btnText) btnText.textContent = 'Wird gesendet...';
      if (btnIcon) btnIcon.classList.add('hidden');
      if (btnSpinner) btnSpinner.classList.remove('hidden');
      if (successMessage) successMessage.classList.add('hidden');
      if (errorMessage) errorMessage.classList.add('hidden');
      
      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
        });
        
        if (response.ok) {
          if (successMessage) successMessage.classList.remove('hidden');
          form.reset();
          successMessage?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          throw new Error('Submission failed');
        }
      } catch (error) {
        if (errorMessage) errorMessage.classList.remove('hidden');
        errorMessage?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } finally {
        if (submitBtn) submitBtn.disabled = false;
        if (btnText) btnText.textContent = 'Nachricht senden';
        if (btnIcon) btnIcon.classList.remove('hidden');
        if (btnSpinner) btnSpinner.classList.add('hidden');
      }
    });
  })();
</script>
