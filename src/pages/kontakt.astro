---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const contactInfo = {
  company: 'METRA Sicherheitsdienste GmbH',
  owner: 'D. Mrkaja',
  address: 'Im Mediapark 5',
  city: '50670 Köln',
  phone: '08008888369',
  phoneDisplay: '0800 8888 369',
  email: 'info@metra-sicherheitsdienste.de',
  web: 'www.metra-sicherheitsdienste.de',
};

// Web3Forms Configuration
const WEB3FORMS_ENDPOINT = 'https://api.web3forms.com/submit';
const WEB3FORMS_ACCESS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY || 'YOUR_ACCESS_KEY'; // Set PUBLIC_WEB3FORMS_KEY in .env file

const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Startseite',
      item: 'https://www.metra-sicherheitsdienste.de',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Kontakt',
      item: 'https://www.metra-sicherheitsdienste.de/kontakt',
    },
  ],
};

const schemaContactPage = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Kontakt - METRA Sicherheitsdienste',
  description: 'Kontaktieren Sie METRA Sicherheitsdienste für Ihr Sicherheitsprojekt.',
  mainEntity: {
    '@type': 'Organization',
    name: contactInfo.company,
    address: {
      '@type': 'PostalAddress',
      streetAddress: contactInfo.address,
      addressLocality: 'Köln',
      postalCode: '50670',
      addressCountry: 'DE',
    },
    telephone: `+49${contactInfo.phone}`,
    email: contactInfo.email,
    url: `https://${contactInfo.web}`,
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: `+49${contactInfo.phone}`,
      contactType: 'customer service',
      availableLanguage: ['German'],
    },
  },
};
---

<Layout 
  title="Kontakt | METRA Sicherheitsdienste GmbH"
  description="Kontaktieren Sie METRA Sicherheitsdienste. Telefon: 0800 8888 369 | E-Mail: info@metra-sicherheitsdienste.de | Adresse: Im Mediapark 5, 50670 Köln."
  canonical="/kontakt"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaContactPage)} />
  
  <Header />
  <MobileMenu />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="relative py-20 md:py-24 overflow-hidden" aria-labelledby="contact-hero-title">
      <div class="absolute inset-0 opacity-5" aria-hidden="true">
        <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
      </div>
      
      <div class="relative max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <nav aria-label="Breadcrumb">
            <ol class="flex items-center gap-2 text-sm text-secondary mb-6">
              <li><a href="/" class="hover:text-accent transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded">Startseite</a></li>
              <li aria-hidden="true">/</li>
              <li aria-current="page" class="text-accent">Kontakt</li>
            </ol>
          </nav>
          
          <p class="text-accent font-semibold tracking-wider text-sm mb-4">KONTAKT</p>
          <h1 id="contact-hero-title" class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
            Projektanfrage & Sicherheitskonzept
          </h1>
          <p class="text-lg md:text-xl text-secondary leading-relaxed max-w-2xl">
            Beschreiben Sie Ihr Objekt oder Projekt. Auf dieser Grundlage erfolgt eine strukturierte Bewertung und Abstimmung der weiteren Schritte.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-16 md:py-24 bg-background/20" aria-labelledby="contact-form-title">
      <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
        <!-- Direct Contact -->
        <div class="max-w-4xl mx-auto mb-16">
          <div class="grid sm:grid-cols-3 gap-8 text-center">
            <div>
              <h3 class="text-white font-semibold mb-2">Telefon</h3>
              <a 
                href={`tel:${contactInfo.phone}`}
                class="text-accent font-semibold hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded"
                aria-label={`Anrufen: ${contactInfo.phoneDisplay}`}
              >
                {contactInfo.phoneDisplay}
              </a>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-2">E-Mail</h3>
              <a 
                href={`mailto:${contactInfo.email}`}
                class="text-accent font-semibold hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded break-all"
                aria-label={`E-Mail: ${contactInfo.email}`}
              >
                {contactInfo.email}
              </a>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-2">WhatsApp</h3>
              <a 
                href="https://wa.me/491738888378"
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent font-semibold hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded"
                aria-label="Über WhatsApp kontaktieren"
              >
                Direkte Anfrage möglich
              </a>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="max-w-2xl mx-auto">
          <div class="bg-background border border-white/5 rounded-2xl p-8 md:p-10">
            <h2 id="contact-form-title" class="text-2xl font-bold text-white mb-2">Anfrage übermitteln</h2>
            <p class="text-secondary mb-8">
              Übermitteln Sie die wichtigsten Projektdaten.
            </p>
            
            <form 
              action={WEB3FORMS_ENDPOINT}
              method="POST"
              id="contact-form"
              class="space-y-6"
              aria-label="Kontaktformular"
            >
              <!-- Web3Forms Access Key -->
              <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
              
              <!-- Subject (Hidden) -->
              <input type="hidden" name="subject" value="Neue Kontaktanfrage über metra-sicherheitsdienste.de" />
              
              <!-- From Name (Hidden) -->
              <input type="hidden" name="from_name" value="METRA Sicherheitsdienste Website Kontaktformular" />
              
              <!-- Reply To (will be set by JS) -->
              <input type="hidden" name="replyto" id="replyto-field" />
              
              <!-- Honeypot Field (Anti-Spam) - Must remain empty -->
              <div class="hidden" aria-hidden="true">
                <input 
                  type="text" 
                  name="botcheck" 
                  id="botcheck"
                  tabindex="-1" 
                  autocomplete="off"
                  aria-hidden="true"
                />
              </div>
              
              <!-- Name Field -->
              <div>
                <label for="name" class="block text-white font-medium mb-2">
                  Name <span class="text-accent">*</span>
                </label>
                <input 
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-white/60 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors"
                  placeholder="Ihr vollständiger Name"
                  aria-required="true"
                />
              </div>
              
              <!-- Email Field -->
              <div>
                <label for="email" class="block text-white font-medium mb-2">
                  E-Mail <span class="text-accent">*</span>
                </label>
                <input 
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-white/60 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors"
                  placeholder="Kontaktadresse"
                  aria-required="true"
                />
              </div>
              
              <!-- Phone Field -->
              <div>
                <label for="phone" class="block text-white font-medium mb-2">
                  Telefon
                </label>
                <input 
                  type="tel"
                  id="phone"
                  name="phone"
                  autocomplete="tel"
                  class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-white/60 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors"
                  placeholder="für Rückfragen"
                />
              </div>

              <!-- Service Interest -->
              <div>
                <label for="service" class="block text-white font-medium mb-2">
                  Leistungsbereich
                </label>
                <select 
                  id="service"
                  name="service"
                  class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors"
                >
                  <option value="" class="bg-background">Bitte wählen...</option>
                  <option value="objektschutz" class="bg-background">Objektschutz</option>
                  <option value="baustellensicherheit" class="bg-background">Baustellensicherheit</option>
                  <option value="werkschutz" class="bg-background">Werkschutz</option>
                  <option value="brandwachen" class="bg-background">Brandwachen</option>
                  <option value="concierge" class="bg-background">Empfang & Concierge</option>
                </select>
              </div>
              
              <!-- Message Field -->
              <div>
                <label for="message" class="block text-white font-medium mb-2">
                  Nachricht
                </label>
                <textarea 
                  id="message"
                  name="message"
                  rows="5"
                  class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-white/60 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors resize-none"
                  placeholder="Beschreiben Sie Ihr Projekt, Einsatzort und Anforderungen."
                ></textarea>
              </div>
              
              <!-- Privacy Checkbox -->
              <div class="flex items-start gap-3">
                <input 
                  type="checkbox"
                  id="privacy"
                  name="privacy"
                  required
                  class="w-5 h-5 mt-0.5 rounded border-white/10 bg-white/5 text-accent focus:ring-accent focus:ring-offset-0 cursor-pointer"
                  aria-required="true"
                />
                <label for="privacy" class="text-secondary text-sm">
                  Ich habe die <a href="/datenschutz" class="text-accent hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zu. <span class="text-accent">*</span>
                </label>
              </div>
              
              <!-- Submit Button -->
              <button 
                type="submit"
                id="submit-btn"
                class="w-full inline-flex items-center justify-center px-8 py-4 bg-accent text-background font-bold text-base rounded hover:bg-accent-hover transition-colors focus:outline-none focus-visible:ring-4 focus-visible:ring-accent/50 disabled:opacity-50 disabled:cursor-not-allowed"
                aria-label="Anfrage übermitteln"
              >
                <span id="btn-text">Anfrage übermitteln</span>
                <svg id="btn-icon" class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
                <svg id="btn-spinner" class="w-5 h-5 ml-2 hidden animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </button>
              
              <!-- Success Message -->
              <div 
                id="success-message" 
                class="hidden p-4 bg-green-500/10 border border-green-500/30 rounded-lg"
                role="alert"
                aria-live="polite"
              >
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <div>
                    <p class="text-white font-medium">Ihre Anfrage wurde übermittelt.</p>
                    <p class="text-secondary text-sm mt-1">Wir prüfen die Angaben und melden uns zur weiteren Abstimmung.</p>
                  </div>
                </div>
              </div>
              
              <!-- Error Message -->
              <div 
                id="error-message" 
                class="hidden p-4 bg-red-500/10 border border-red-500/30 rounded-lg"
                role="alert"
                aria-live="polite"
              >
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                  </svg>
                  <div>
                    <p class="text-white font-medium">Es ist ein Fehler aufgetreten.</p>
                    <p class="text-secondary text-sm mt-1">Bitte versuchen Sie es später erneut oder kontaktieren Sie uns telefonisch.</p>
                  </div>
                </div>
              </div>
            </form>
            
            <!-- Trust Block -->
            <div class="mt-8 p-6 bg-white/5 border border-white/5 rounded-xl">
              <p class="text-secondary text-sm leading-relaxed">
                Alle Anfragen werden strukturiert erfasst und vertraulich behandelt. Die weitere Abstimmung erfolgt auf Grundlage Ihrer Angaben und der projektspezifischen Anforderungen.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>


  </main>
  
  <Footer />
  <WhatsAppButton />
</Layout>

<script>
  // Form handling
  (function() {
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const btnIcon = document.getElementById('btn-icon');
    const btnSpinner = document.getElementById('btn-spinner');
    const successMessage = document.getElementById('success-message');
    const errorMessage = document.getElementById('error-message');
    const replyToField = document.getElementById('replyto-field');
    const emailField = document.getElementById('email');
    
    if (!form) return;
    
    // Update replyto field when email changes
    emailField?.addEventListener('input', function() {
      if (replyToField) {
        replyToField.value = this.value;
      }
    });
    
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      // Check honeypot - if filled, it's a bot
      const botcheck = document.getElementById('botcheck');
      if (botcheck && botcheck.value) {
        return;
      }
      
      // Show loading state
      if (submitBtn) submitBtn.disabled = true;
      if (btnText) btnText.textContent = 'Wird gesendet...';
      if (btnIcon) btnIcon.classList.add('hidden');
      if (btnSpinner) btnSpinner.classList.remove('hidden');
      if (successMessage) successMessage.classList.add('hidden');
      if (errorMessage) errorMessage.classList.add('hidden');
      
      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
        });
        
        if (response.ok) {
          if (successMessage) successMessage.classList.remove('hidden');
          form.reset();
          successMessage?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          throw new Error('Submission failed');
        }
      } catch (error) {
        if (errorMessage) errorMessage.classList.remove('hidden');
        errorMessage?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } finally {
        if (submitBtn) submitBtn.disabled = false;
        if (btnText) btnText.textContent = 'Anfrage übermitteln';
        if (btnIcon) btnIcon.classList.remove('hidden');
        if (btnSpinner) btnSpinner.classList.add('hidden');
      }
    });
  })();
</script>
